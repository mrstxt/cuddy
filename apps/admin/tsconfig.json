{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
