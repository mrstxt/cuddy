# Cuddy Pro env namunasi
#
# API talab qiladigan funksiyalar:
# - Code Translator va Code Checker: OPENAI_API_KEY, OPENAI_MODEL
# - Background Remover: PHOTOROOM_API_KEY
# - Photo Enhancer: PICSART_API_KEY
# - Admin state, support chat, user auth va limit sync: NEXT_PUBLIC_API_URL + Python backend

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

PHOTOROOM_API_KEY=
PICSART_API_KEY=

# Admin panelga birinchi kirish uchun bootstrap account.
# Backend birinchi ishga tushganda admins.json bo'sh bo'lsa shu account yaratiladi.
ADMIN_BOOTSTRAP_USERNAME=sohibjon-pro
ADMIN_BOOTSTRAP_PASSWORD=sohibjonn12
ADMIN_BOOTSTRAP_NAME=Sohibjon Sulaymonov

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Fly.io production namunasi
# NEXT_PUBLIC_SITE_URL=https://cuddy.uz
# NEXT_PUBLIC_ADMIN_URL=https://admin.cuddy.uz
# NEXT_PUBLIC_API_URL=https://api.cuddy.uz
# FRONTEND_ORIGINS=https://cuddy.uz,https://admin.cuddy.uz
