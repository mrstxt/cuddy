{
  "name": "cuddy-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "web:dev": "npm --prefix cuddy-pro run dev",
    "web:build": "npm --prefix cuddy-pro run build",
    "web:lint": "npm --prefix cuddy-pro run lint",
    "admin:dev": "npm --prefix admin run dev",
    "admin:build": "npm --prefix admin run build",
    "admin:lint": "npm --prefix admin run lint",
    "lint": "npm run web:lint && npm run admin:lint",
    "build": "npm run web:build && npm run admin:build"
  }
}
